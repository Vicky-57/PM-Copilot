# Gemini API Key (Optional)
# GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Settings (Prioritized if set)
# Get your API key from Groq Console: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Server Settings
HOST=127.0.0.1
PORT=8000

# Jira Integration Settings
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=PROJ

# Notion Integration Settings
NOTION_API_KEY=secret_your_notion_api_token_here
NOTION_PARENT_PAGE_ID=your_notion_parent_page_uuid

# Linear Integration Settings
LINEAR_API_KEY=lin_api_your_key_here
LINEAR_TEAM_ID=your_linear_team_uuid_here




# Scanner Settings
# Limits how many tokens of source code are read directly to avoid exceeding model windows
MAX_SCAN_TOKENS=500000

# Slack Integration Settings
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your_slack_webhook_url_here

# Git Integration Settings
GITHUB_ACCESS_TOKEN=ghp_your_github_token_here
GITLAB_ACCESS_TOKEN=glpat-your_gitlab_token_here
